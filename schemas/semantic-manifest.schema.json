{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Atlas Splitter semantic manifest",
  "type": "object",
  "required": ["source_manifest", "groups", "unassigned_piece_ids"],
  "properties": {
    "source_manifest": {"const": "manifest.json"}, "backend": {"type": "string"}, "model": {"type": "string"}, "device": {"type": "string"}, "elapsed_seconds": {"type": "number"},
    "groups": {"type": "array", "items": {"type": "object", "required": ["group_id", "name", "piece_ids", "confidence", "status"], "properties": {"group_id": {"type": "string"}, "name": {"type": "string"}, "slug": {"type": "string"}, "piece_ids": {"type": "array", "items": {"type": "string"}}, "confidence": {"type": "number", "minimum": 0, "maximum": 1}, "status": {"enum": ["accepted", "uncertain", "rejected"]}, "preview": {"type": "string"}, "psd": {"type": "string"}, "pieces": {"type": "array", "items": {"type": "string"}}}},
    "unassigned_piece_ids": {"type": "array", "items": {"type": "string"}}
  }
}
